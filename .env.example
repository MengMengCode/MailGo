# ═══════════════════════════════════════════════════════════════
#  MailGo Environment Configuration
#  Auto-generated by install.sh. Edit as needed.
# ═══════════════════════════════════════════════════════════════

# ── Encryption key (auto-generated, DO NOT share) ──────────────
ENCRYPTION_KEY=

# ── Server port ─────────────────────────────────────────────────
SERVER_PORT=8080

# Docker image tag used by docker-compose.yml.
# Use latest for the newest release, or pin a version like 0.2.1.
MAILGO_IMAGE_TAG=latest

# Additional trusted reverse proxy IPs/CIDRs, comma-separated. Same-host
# Nginx/Caddy is trusted automatically because loopback is enabled by default.
TRUSTED_PROXIES=

# ── MySQL (container-internal, do not change for default setup) ─
MYSQL_USER=mailgo
MYSQL_PASSWORD=
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=mailgo
MYSQL_ROOT_PASSWORD=

# ── Redis (container-internal, do not change for default setup) ─
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
